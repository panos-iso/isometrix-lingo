<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsometrixLingo.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
        x:Class="IsometrixLingo.Views.WelcomeWindow"
        x:DataType="vm:WelcomeViewModel"
        Title="Welcome to Translation Management Tool"
        Width="450" Height="280"
        CanResize="False"
        WindowStartupLocation="CenterScreen">

    <StackPanel Margin="20" Spacing="15">
        <TextBlock Text="Welcome!" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
        <TextBlock Text="Please enter your name to get started:" TextWrapping="Wrap"/>
        <TextBox Text="{Binding Username}" PlaceholderText="Enter your name"/>
        
        <Border BorderBrush="#E0E0E0"
                BorderThickness="1"
                CornerRadius="6"
                Padding="15"
                Background="#F5F5F5"
                Margin="0,5,0,0">
            <StackPanel Spacing="10">
                <TextBlock Text="User Type" 
                           FontSize="14" 
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                <CheckBox IsChecked="{Binding IsDeveloper}">
                    <TextBlock TextWrapping="Wrap">
                        <Run Text="I am a developer/engineer"/>
                    </TextBlock>
                </CheckBox>
                <TextBlock Text="Developers see advanced features like deployment mode and technical warnings."
                           FontSize="11"
                           FontStyle="Italic"
                           TextWrapping="Wrap"
                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
            </StackPanel>
        </Border>
        
        <Button Content="Continue" 
                HorizontalAlignment="Center" 
                Click="OnContinueClick"
                IsEnabled="{Binding Username, Converter={x:Static StringConverters.IsNotNullOrEmpty}}"/>
    </StackPanel>

</Window>
