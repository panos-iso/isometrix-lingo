<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="IsometrixLingo.Views.BranchWarningDialog"
        Title="Important: Branch Status Check"
        Width="550"
        Height="300"
        WindowStartupLocation="CenterOwner"
        CanResize="False">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Warning Icon and Title -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="⚠️" FontSize="24" Margin="0,0,10,0"/>
            <TextBlock Text="Repository Status Verification" 
                       FontSize="16" 
                       FontWeight="Bold"
                       VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Warning Message -->
        <Border Grid.Row="1" 
                Background="#FFF3CD" 
                BorderBrush="#FFC107" 
                BorderThickness="1" 
                CornerRadius="4"
                Padding="15"
                Margin="0,0,0,15">
            <StackPanel Spacing="10">
                <TextBlock TextWrapping="Wrap" FontWeight="SemiBold">
                    Before importing translation files, please ensure:
                </TextBlock>
                <StackPanel Spacing="5" Margin="15,0,0,0">
                    <TextBlock TextWrapping="Wrap">
                        • All repositories are on the correct branch for translation work
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap">
                        • All repositories have been pulled to get the latest changes
                    </TextBlock>
                    <TextBlock TextWrapping="Wrap">
                        • No uncommitted changes exist in translation files
                    </TextBlock>
                </StackPanel>
                <TextBlock TextWrapping="Wrap" FontStyle="Italic" Margin="0,5,0,0">
                    This ensures you're working with the correct and most up-to-date translations.
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- Confirmation Checkbox -->
        <CheckBox Grid.Row="2" 
                  x:Name="ConfirmationCheckBox"
                  Margin="0,0,0,20">
            <TextBlock TextWrapping="Wrap">
                I confirm all repositories are on the correct branch and up to date
            </TextBlock>
        </CheckBox>

        <!-- Buttons -->
        <StackPanel Grid.Row="3" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Right" 
                    Spacing="10">
            <Button Content="Cancel" 
                    Width="100" 
                    Click="OnCancelClick"/>
            <Button Content="Proceed" 
                    Width="100" 
                    x:Name="ProceedButton"
                    IsEnabled="{Binding #ConfirmationCheckBox.IsChecked}"
                    Click="OnProceedClick"
                    Classes="accent"/>
        </StackPanel>
    </Grid>
</Window>
