<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IsometrixLingo.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
             x:Class="IsometrixLingo.Views.WorkflowStepsControl"
             x:DataType="vm:MainWindowViewModel">
    
    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="10">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            
            <!-- Step 1: Import -->
            <Border Grid.Column="0" 
                    Background="{Binding Step1Background}"
                    CornerRadius="4"
                    Margin="0,0,3,0"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="Step 1" 
                               FontSize="11" 
                               Foreground="{Binding Step1Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Import Files" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step1Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step1Status}" 
                               FontSize="10" 
                               Foreground="{Binding Step1Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 2: File Mapping -->
            <Border Grid.Column="1" 
                    Background="{Binding Step2Background}"
                    CornerRadius="4"
                    Margin="3,0,3,0"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="Step 2" 
                               FontSize="11" 
                               Foreground="{Binding Step2Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Confirm Pairs" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step2Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step2Status}" 
                               FontSize="10" 
                               Foreground="{Binding Step2Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 3: Mode Selection -->
            <Border Grid.Column="2" 
                    Background="{Binding Step3Background}"
                    CornerRadius="4"
                    Margin="3,0,3,0"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="Step 3" 
                               FontSize="11" 
                               Foreground="{Binding Step3Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Choose Mode" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step3Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step3Status}" 
                               FontSize="10" 
                               Foreground="{Binding Step3Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 4: Edit/Suggest -->
            <Border Grid.Column="3" 
                    Background="{Binding Step4Background}"
                    CornerRadius="4"
                    Margin="3,0,3,0"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="Step 4" 
                               FontSize="11" 
                               Foreground="{Binding Step4Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Edit/Suggest" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step4Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step4Status}" 
                               FontSize="10" 
                               Foreground="{Binding Step4Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 5: Export -->
            <Border Grid.Column="4" 
                    Background="{Binding Step5Background}"
                    CornerRadius="4"
                    Margin="3,0,3,0"
                    Padding="12,10">
                <StackPanel>
                    <TextBlock Text="Step 5" 
                               FontSize="11" 
                               Foreground="{Binding Step5Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Export Files" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step5Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step5Status}" 
                               FontSize="10" 
                               Foreground="{Binding Step5Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 6: Deploy (Developer Only) -->
            <Border Grid.Column="5" 
                    Background="{Binding Step6Background}"
                    CornerRadius="4"
                    Margin="3,0,0,0"
                    Padding="12,10"
                    IsVisible="{Binding IsDeveloper}">
                <StackPanel>
                    <TextBlock Text="Step 6" 
                               FontSize="11" 
                               Foreground="{Binding Step6Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Deploy" 
                               FontSize="13" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step6Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step6Status}" 
                               FontSize="10" 
                               Foreground="{Binding Step6Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
