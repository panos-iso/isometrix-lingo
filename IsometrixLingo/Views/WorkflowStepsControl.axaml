<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:IsometrixLingo.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="60"
             x:Class="IsometrixLingo.Views.WorkflowStepsControl"
             x:DataType="vm:MainWindowViewModel">
    
    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" BorderThickness="0,0,0,1" Padding="10">
        <Grid ColumnDefinitions="*,*,*">
            <!-- Step 1: Import -->
            <Border Grid.Column="0" 
                    Background="{Binding Step1Background}"
                    CornerRadius="4"
                    Margin="0,0,5,0"
                    Padding="15,10">
                <StackPanel>
                    <TextBlock Text="Step 1" 
                               FontSize="12" 
                               Foreground="{Binding Step1Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Import Files" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step1Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step1Status}" 
                               FontSize="11" 
                               Foreground="{Binding Step1Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 2: Edit -->
            <Border Grid.Column="1" 
                    Background="{Binding Step2Background}"
                    CornerRadius="4"
                    Margin="5,0,5,0"
                    Padding="15,10">
                <StackPanel>
                    <TextBlock Text="Step 2" 
                               FontSize="12" 
                               Foreground="{Binding Step2Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Edit Translations" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step2Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step2Status}" 
                               FontSize="11" 
                               Foreground="{Binding Step2Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>

            <!-- Step 3: Export -->
            <Border Grid.Column="2" 
                    Background="{Binding Step3Background}"
                    CornerRadius="4"
                    Margin="5,0,0,0"
                    Padding="15,10">
                <StackPanel>
                    <TextBlock Text="Step 3" 
                               FontSize="12" 
                               Foreground="{Binding Step3Foreground}"
                               Opacity="0.8"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Export Files" 
                               FontSize="14" 
                               FontWeight="SemiBold"
                               Foreground="{Binding Step3Foreground}"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                    <TextBlock Text="{Binding Step3Status}" 
                               FontSize="11" 
                               Foreground="{Binding Step3Foreground}"
                               Opacity="0.9"
                               HorizontalAlignment="Center"
                               Margin="0,2,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</UserControl>
