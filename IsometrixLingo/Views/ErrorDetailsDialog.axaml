<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsometrixLingo.ViewModels"
        xmlns:models="using:IsometrixLingo.Models"
        x:Class="IsometrixLingo.Views.ErrorDetailsDialog"
        x:DataType="vm:ErrorDetailsViewModel"
        Title="Import Errors"
        Width="700"
        Height="500"
        WindowStartupLocation="CenterOwner"
        CanResize="true">

    <Window.Styles>
        <Style Selector="Border.error-item">
            <Setter Property="Background" Value="#FFF3F3" />
            <Setter Property="BorderBrush" Value="#E57373" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        
        <Style Selector="TextBlock.error-filename">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="14" />
            <Setter Property="Foreground" Value="#D32F2F" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        
        <Style Selector="TextBlock.error-message">
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="#424242" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        
        <Style Selector="TextBlock.error-guidance">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="FontStyle" Value="Italic" />
            <Setter Property="Foreground" Value="#757575" />
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#D32F2F" 
                Padding="16">
            <StackPanel>
                <TextBlock Text="Import Errors" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Foreground="White" />
                <TextBlock Text="The following errors occurred while importing files. Please fix them and try again." 
                           FontSize="13" 
                           Foreground="White" 
                           TextWrapping="Wrap" 
                           Margin="0,4,0,0" />
            </StackPanel>
        </Border>

        <!-- Error List -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto">
            <Border Padding="16">
                <ItemsControl ItemsSource="{Binding ImportErrors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:ImportError">
                            <Border Classes="error-item">
                                <StackPanel>
                                    <TextBlock Classes="error-filename" 
                                              Text="{Binding FileName}" />
                                    <TextBlock Classes="error-message" 
                                              Text="{Binding Message}" />
                                    <TextBlock Classes="error-guidance" 
                                              Text="{Binding Guidance}" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>
        </ScrollViewer>

        <!-- Close Button -->
        <Border Grid.Row="2" 
                Background="#D32F2F" 
                BorderBrush="#B71C1C" 
                BorderThickness="0,1,0,0" 
                Padding="12">
            <Button Content="Close" 
                    HorizontalAlignment="Right" 
                    Width="100"
                    Background="White"
                    Foreground="#D32F2F"
                    FontWeight="SemiBold"
                    Click="OnCloseClick" />
        </Border>
    </Grid>
</Window>
