<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsometrixLingo.ViewModels"
        xmlns:models="using:IsometrixLingo.Models"
        x:Class="IsometrixLingo.Views.DeploymentDetailsDialog"
        x:DataType="vm:DeploymentDetailsViewModel"
        Title="{Binding Title}"
        Width="900"
        Height="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,15">
            <TextBlock Text="{Binding Title}"
                       FontSize="18"
                       FontWeight="Bold"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            <TextBlock Text="{Binding Subtitle}"
                       FontSize="14"
                       Margin="0,5,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <!-- Content -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="10">
                <!-- Deployment Preview Items -->
                <ItemsControl ItemsSource="{Binding PreviewItems}"
                              IsVisible="{Binding ShowPreviewItems}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:DeploymentPreviewItem">
                            <Border Background="#F5F5F5"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="4"
                                    Padding="12"
                                    Margin="0,0,0,8">
                                <Grid ColumnDefinitions="*,Auto,*">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding SourcePath}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               FontFamily="Courier New"
                                               Foreground="#212121"/>
                                    <TextBlock Grid.Column="1"
                                               Text=" → "
                                               FontSize="14"
                                               FontWeight="Bold"
                                               Margin="10,0"
                                               Foreground="#4CAF50"/>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding TargetPath}"
                                               FontSize="12"
                                               TextWrapping="Wrap"
                                               FontFamily="Courier New"
                                               Foreground="#212121"/>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- Error Items -->
                <ItemsControl ItemsSource="{Binding Errors}"
                              IsVisible="{Binding ShowErrors}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:ImportError">
                            <Border Background="#FFEBEE"
                                    BorderBrush="#EF5350"
                                    BorderThickness="2"
                                    CornerRadius="6"
                                    Padding="15"
                                    Margin="0,0,0,10">
                                <StackPanel Spacing="8">
                                    <Grid ColumnDefinitions="Auto,*">
                                        <TextBlock Grid.Column="0"
                                                   Text="❌"
                                                   FontSize="16"
                                                   Margin="0,0,10,0"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding FileName}"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   Foreground="#C62828"/>
                                    </Grid>
                                    <TextBlock Text="{Binding Message}"
                                               FontSize="13"
                                               TextWrapping="Wrap"
                                               Margin="26,0,0,0"
                                               Foreground="#424242"/>
                                    <TextBlock Text="{Binding Guidance}"
                                               FontSize="12"
                                               FontStyle="Italic"
                                               TextWrapping="Wrap"
                                               Margin="26,0,0,0"
                                               Foreground="#757575"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!-- History Entries -->
                <ItemsControl ItemsSource="{Binding HistoryEntries}"
                              IsVisible="{Binding ShowHistory}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="models:DeploymentHistoryEntry">
                            <Border Background="#FAFAFA"
                                    BorderBrush="#E0E0E0"
                                    BorderThickness="1"
                                    CornerRadius="6"
                                    Padding="15"
                                    Margin="0,0,0,10">
                                <Grid ColumnDefinitions="Auto,*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding StatusIcon}"
                                               FontSize="24"
                                               Margin="0,0,15,0"
                                               VerticalAlignment="Center"
                                               Foreground="{Binding StatusColor}"/>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding FormattedTimestamp}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#212121"/>
                                        <TextBlock FontSize="12"
                                                   Foreground="#757575"
                                                   Margin="0,3,0,0">
                                            <Run Text="{Binding FileCount}"/>
                                            <Run Text="file(s) •"/>
                                            <Run Text="{Binding StatusText}"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding DeploymentRoot}"
                                                   FontSize="11"
                                                   FontFamily="Courier New"
                                                   Foreground="#9E9E9E"
                                                   Margin="0,3,0,0"
                                                   TextWrapping="Wrap"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </StackPanel>
        </ScrollViewer>

        <!-- Close Button -->
        <Button Grid.Row="2"
                Content="Close"
                Width="100"
                HorizontalAlignment="Right"
                Margin="0,15,0,0"
                Click="OnCloseClick"/>
    </Grid>
</Window>
