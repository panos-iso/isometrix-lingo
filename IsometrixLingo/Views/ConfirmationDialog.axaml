<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="250"
        x:Class="IsometrixLingo.Views.ConfirmationDialog"
        Title="Confirm Export"
        Width="520" Height="250"
        WindowStartupLocation="CenterOwner"
        CanResize="False">
    
    <Grid Margin="20" RowDefinitions="Auto,*,Auto">
        <TextBlock Grid.Row="0"
                   x:Name="HeaderText"
                   Text="⚠️ Warning"
                   FontSize="18"
                   FontWeight="Bold"
                   HorizontalAlignment="Center"
                   Margin="0,0,0,15"/>
        
        <TextBlock Grid.Row="1"
                   x:Name="MessageText"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   TextAlignment="Center"
                   VerticalAlignment="Top"
                   MaxWidth="480"/>
        
        <StackPanel Grid.Row="2" 
                    Orientation="Horizontal" 
                    HorizontalAlignment="Center" 
                    Spacing="15"
                    Margin="0,20,0,0">
            <Button Content="Stay and Add Missing Terms"
                    Click="OnStayClicked"
                    Padding="15,8"
                    MinWidth="180"/>
            <Button Content="Continue Anyway"
                    Click="OnContinueClicked"
                    Padding="15,8"
                    MinWidth="130"/>
        </StackPanel>
    </Grid>
</Window>
