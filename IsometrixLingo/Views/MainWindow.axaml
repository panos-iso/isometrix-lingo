<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:IsometrixLingo.ViewModels"
        xmlns:views="using:IsometrixLingo.Views"
        xmlns:models="using:IsometrixLingo.Models"
        xmlns:converters="using:IsometrixLingo.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="IsometrixLingo.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/lingo-icon.png"
        Title="Isometrix Lingo"
        Width="1000" Height="650"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaTitleBarHeightHint="40">

    <Window.Resources>
        <converters:SourceFileConverter x:Key="SourceFileConverter"/>
        <converters:SourceFileDisplayConverter x:Key="SourceFileDisplayConverter"/>
        <converters:SourceFileMinimalPathConverter x:Key="SourceFileMinimalPathConverter"/>
        <converters:SourceFileMinimalPathMultiConverter x:Key="SourceFileMinimalPathMultiConverter"/>
        <converters:TruncatedDirectoryPathConverter x:Key="TruncatedDirectoryPathConverter"/>
        <converters:ShowFiltersTextConverter x:Key="ShowFiltersTextConverter"/>
        <converters:ShowOriginalTooltipConverter x:Key="ShowOriginalTooltipConverter"/>
        <converters:RowToggleEnabledConverter x:Key="RowToggleEnabledConverter"/>
        <converters:MissingTranslationBorderConverter x:Key="MissingTranslationBorderConverter"/>
        <converters:ConfirmationForegroundConverter x:Key="ConfirmationForegroundConverter"/>
    </Window.Resources>
    
    <Window.Styles>
        <!-- Global button style for centered content -->
        <Style Selector="Button">
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        
        <Style Selector="Button.ImportButton">
            <Setter Property="Background" Value="#2196F3"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#1976D2"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.ImportButton:pointerover">
            <Setter Property="Background" Value="#1976D2"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.ImportButton:pressed">
            <Setter Property="Background" Value="#0D47A1"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.PrimaryButton">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
        <Style Selector="Button.PrimaryButton:pointerover">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.PrimaryButton:pressed">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        
        <Style Selector="Button.ExportButton">
            <Setter Property="Background" Value="#4CAF50"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#388E3C"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="16"/>
        </Style>
        <Style Selector="Button.ExportButton:pointerover">
            <Setter Property="Background" Value="#388E3C"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.ExportButton:pressed">
            <Setter Property="Background" Value="#2E7D32"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Panel>
        <!-- Custom Title Bar -->
        <Grid Height="40" VerticalAlignment="Top" ColumnDefinitions="70,Auto,*,Auto,Auto">
            <!-- Spacer for native window controls (macOS left side) -->
            <Border Grid.Column="0" IsHitTestVisible="False"/>
            
            <!-- App Title and Version (Top Left) -->
            <TextBlock Grid.Column="1"
                       Text="Isometrix Lingo v3.3.2"
                       FontSize="13"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Margin="5,2,0,0"
                       IsHitTestVisible="False"/>
            
            <!-- Center spacer -->
            <Border Grid.Column="2" IsHitTestVisible="False"/>
            
            <!-- User Greeting -->
            <TextBlock Grid.Column="3"
                       FontSize="13"
                       VerticalAlignment="Center"
                       Margin="0,0,10,0"
                       IsHitTestVisible="False">
                <Run Text="Hello, "/>
                <Run Text="{Binding Username}"/>
                <Run Text=" 👋"/>
            </TextBlock>
            
            <!-- User Profile Button -->
            <Button Grid.Column="4"
                    Content="👤" 
                    Command="{Binding ShowProfileCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    FontSize="14"
                    Padding="6,2"
                    Margin="0,0,10,0"
                    VerticalAlignment="Center">
                <ToolTip.Tip>
                    <TextBlock>
                        <Run Text="View profile"/>
                    </TextBlock>
                </ToolTip.Tip>
            </Button>
        </Grid>
        
        <!-- Main Content -->
        <DockPanel Margin="0,40,0,0">

        <!-- Workflow Steps Progress Bar -->
        <views:WorkflowStepsControl DockPanel.Dock="Top" DataContext="{Binding}"/>

        <!-- Bottom Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource SystemControlBackgroundBaseLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="10,5">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>
                <Button Grid.Column="1"
                        Content="View Error Details"
                        Command="{Binding ShowErrorDetailsCommand}"
                        CommandParameter="{Binding $parent[Window]}"
                        IsVisible="{Binding HasErrors}"
                        Background="#D32F2F"
                        Foreground="White"
                        Padding="12,6"
                        Margin="10,0,0,0"
                        CornerRadius="4"
                        FontSize="12"
                        FontWeight="SemiBold"/>
            </Grid>
        </Border>

        <!-- Main Content Area - Changes based on current step -->
        <Grid Margin="20">
            <!-- Step 1: Import Files -->
            <DockPanel IsVisible="{Binding ShowImportStep}" LastChildFill="True">
                    <!-- Buttons at bottom -->
                    <StackPanel DockPanel.Dock="Bottom"
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Spacing="10"
                                Margin="0,15,0,0">
                        <Button Content="{Binding StartOverButtonText}"
                                Command="{Binding StartOverCommand}"
                                IsEnabled="{Binding HasKeys}"
                                Padding="15,8"/>
                        <Button Content="Next →"
                                Classes="PrimaryButton"
                                Command="{Binding ConfirmImportCommand}"
                                IsEnabled="{Binding HasKeys}"
                                Padding="15,8"
                                FontWeight="SemiBold"/>
                    </StackPanel>

                    <!-- Header at top -->
                    <StackPanel DockPanel.Dock="Top" Spacing="5" Margin="0,0,0,15">
                        <TextBlock Text="Step 1: Import Translation Files"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="Import translation files by selecting a directory containing your translations (JSON or RESX format)."
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <!-- Scrollable content -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Spacing="15">

                            <!-- Two-column layout: Drop zone + File list (65/35 split) -->
                            <Grid ColumnDefinitions="1.85*,*" ColumnSpacing="15">
                                <!-- Left Column: Drop Zone -->
                                <Border Grid.Column="0"
                                        BorderBrush="#2196F3"
                                        BorderThickness="3"
                                        Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                        CornerRadius="8"
                                        MinHeight="250"
                                        Padding="20"
                                        x:Name="DropZone">
                                    <Grid>
                                        <!-- Invisible overlay to capture drag events across entire area -->
                                        <Border Background="Transparent" x:Name="DropOverlay"/>
                                        
                                        <!-- Content -->
                                        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                                            <TextBlock Text="📁" FontSize="42" HorizontalAlignment="Center"/>
                                            <TextBlock Text="Drag &amp; drop a directory here" 
                                                       FontSize="16" 
                                                       FontWeight="Bold"
                                                       HorizontalAlignment="Center"
                                                       Foreground="#2196F3"/>
                                            <TextBlock Text="or click the button below to choose a directory" 
                                                       FontSize="12" 
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                       MaxWidth="300"
                                                       TextWrapping="Wrap"
                                                       Margin="0,0,0,10"/>
                                            
                                            <!-- Import Button -->
                                            <Button Content="Import Directory"
                                                    Classes="ImportButton"
                                                    Command="{Binding BulkImportFromDirectoryCommand}"
                                                    CommandParameter="{Binding $parent[Window]}"
                                                    Padding="20,10"
                                                    FontSize="14"
                                                    FontWeight="SemiBold"
                                                    HorizontalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <!-- Right Column: Imported Files List -->
                                <Border Grid.Column="1"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                        BorderThickness="1"
                                        Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                        CornerRadius="8"
                                        Padding="10"
                                        Height="250"
                                        IsVisible="{Binding HasKeys}">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Top"
                                                   Text="Imported Files"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,10"/>
                                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsControl ItemsSource="{Binding ImportedFileNames}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Spacing="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#E3F2FD"
                                                                BorderBrush="#90CAF9"
                                                                BorderThickness="1"
                                                                CornerRadius="3"
                                                                Padding="8,6">
                                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                                <TextBlock Text="📎" FontSize="12" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding}" 
                                                                           FontSize="12"
                                                                           Foreground="#0D47A1"
                                                                           VerticalAlignment="Center"
                                                                           FontWeight="Medium"
                                                                           TextWrapping="Wrap"/>
                                                            </StackPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </ScrollViewer>
                                    </DockPanel>
                                </Border>
                            </Grid>

                            <!-- Ignored Files Section -->
                            <Border BorderBrush="#FF9800"
                                    BorderThickness="1"
                                    Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                    CornerRadius="8"
                                    Padding="15"
                                    Margin="0,10,0,0"
                                    IsVisible="{Binding !!IgnoredFileNames.Count}">
                                <DockPanel>
                                    <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,10">
                                        <TextBlock Text="⚠"
                                                   FontSize="16"
                                                   VerticalAlignment="Center"
                                                   Foreground="#FF9800"/>
                                        <TextBlock Text="Ignored Files (Unsupported Language)"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                    <TextBlock DockPanel.Dock="Top"
                                               Text="The following files were ignored because they use unsupported languages. Only English (en) and Spanish (es) are supported."
                                               FontSize="12"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding IgnoredFileNames}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <StackPanel Spacing="6"/>
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#FFF3E0"
                                                        BorderBrush="#FFB74D"
                                                        BorderThickness="1"
                                                        CornerRadius="3"
                                                        Padding="8,6">
                                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                                        <TextBlock Text="🚫" FontSize="12" VerticalAlignment="Center"/>
                                                        <TextBlock Text="{Binding}" 
                                                                   FontSize="12"
                                                                   Foreground="#E65100"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="Medium"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </DockPanel>
                            </Border>
                    </StackPanel>
                    </ScrollViewer>
                </DockPanel>

            <!-- Step 2: File Mapping -->
            <DockPanel IsVisible="{Binding ShowFileMappingStep}" LastChildFill="True">
                <!-- Buttons at bottom -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Spacing="10"
                            Margin="0,15,0,0">
                    <Button Content="{Binding StartOverButtonText}"
                            Command="{Binding StartOverCommand}"
                            Padding="15,8"/>
                    <Button Content="Next →"
                            Classes="PrimaryButton"
                            Command="{Binding ConfirmFileMappingCommand}"
                            CommandParameter="{Binding $parent[Window]}"
                            Padding="15,8"
                            FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Header at top -->
                <StackPanel DockPanel.Dock="Top" Spacing="5" Margin="0,0,0,15">
                    <TextBlock Text="Step 2: Confirm File Pairs"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Text="Review the detected file pairs below. For missing pair files, you can create empty files with all keys but no values."
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <!-- Scrollable content -->
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15">

                        <!-- File Pairs List -->
                        <ItemsControl ItemsSource="{Binding FilePairs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Spacing="10"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                            BorderThickness="1"
                                            Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                            CornerRadius="8"
                                            Padding="15">
                                        <Grid RowDefinitions="Auto,Auto,Auto,Auto">
                                            <!-- Header -->
                                            <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                                                <StackPanel Grid.Column="0" Spacing="2">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="16"
                                                               FontWeight="SemiBold"/>
                                                    <TextBlock Text="{Binding TruncatedDirectoryPath}"
                                                               FontSize="10"
                                                               FontStyle="Italic"
                                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                               IsVisible="{Binding DirectoryPath, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding StatusText}"
                                                           FontSize="14"
                                                           VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- English File -->
                                            <Grid Grid.Row="1" ColumnDefinitions="100,*,Auto" Margin="0,5,0,0">
                                                <TextBlock Grid.Column="0"
                                                           Text="English:"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding EnglishFileName, FallbackValue='(missing)'}"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0"/>
                                                <CheckBox Grid.Column="2"
                                                          Content="Create empty file"
                                                          IsChecked="{Binding CreateMissingEnglish}"
                                                          IsVisible="{Binding !HasEnglishFile}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>

                                            <!-- Spanish File -->
                                            <Grid Grid.Row="2" ColumnDefinitions="100,*,Auto" Margin="0,5,0,0">
                                                <TextBlock Grid.Column="0"
                                                           Text="Spanish:"
                                                           FontWeight="SemiBold"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Grid.Column="1"
                                                           Text="{Binding SpanishFileName, FallbackValue='(missing)'}"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0"/>
                                                <CheckBox Grid.Column="2"
                                                          Content="Create empty file"
                                                          IsChecked="{Binding CreateMissingSpanish}"
                                                          IsVisible="{Binding !HasSpanishFile}"
                                                          VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>

            <!-- Step 3: Mode Selection -->
            <DockPanel IsVisible="{Binding ShowModeSelectionStep}" LastChildFill="True">
                <!-- Buttons at bottom -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Spacing="10"
                            Margin="0,15,0,0">
                    <Button Content="{Binding StartOverButtonText}"
                            Command="{Binding StartOverCommand}"
                            Padding="15,8"/>
                    <Button Content="Next →"
                            Classes="PrimaryButton"
                            Command="{Binding ConfirmModeSelectionCommand}"
                            Padding="15,8"
                            FontWeight="SemiBold"/>
                </StackPanel>

                <!-- Main content -->
                <StackPanel Spacing="20">
                    <!-- Header -->
                    <StackPanel Spacing="10">
                        <TextBlock Text="Step 3: Choose Your Mode"
                                   FontSize="20"
                                   FontWeight="Bold"
                                   Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                        <TextBlock Text="Select how you want to work with translations. You cannot change modes during this session."
                                   TextWrapping="Wrap"
                                   FontSize="14"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>

                    <!-- Mode Selection Boxes -->
                    <Grid Margin="0,20,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        
                        <!-- Edit Mode Box -->
                        <Border Grid.Column="0"
                                Background="#E3F2FD"
                                BorderThickness="{Binding CurrentMode, Converter={StaticResource ModeSelectionBorderThicknessConverter}, ConverterParameter=Edit}"
                                CornerRadius="10"
                                Padding="30"
                                Cursor="Hand"
                                Tapped="OnEditModeBoxTapped"
                                BoxShadow="0 4 8 0 #40000000">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding CurrentMode, Converter={StaticResource ModeSelectionBorderColorConverter}, ConverterParameter=Edit}"/>
                            </Border.BorderBrush>
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="BoxShadow" Value="0 6 16 0 #60000000"/>
                                </Style>
                            </Border.Styles>
                            <StackPanel Spacing="15">
                                <TextBlock Text="✏️ Edit Mode"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#0D47A1"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Directly modify translation values"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Foreground="#1976D2"/>
                                <Border Height="2" Background="#BBDEFB" Margin="0,5,0,5"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#424242">
                                    <Run Text="• Edit actual translation values"/><LineBreak/>
                                    <Run Text="• Add new translation keys"/><LineBreak/>
                                    <Run Text="• Review and accept/reject suggestions"/><LineBreak/>
                                    <Run Text="• Full control over all translations"/>
                                </TextBlock>
                                <!-- Selected indicator -->
                                <Border Background="#1976D2"
                                        CornerRadius="5"
                                        Padding="10,5"
                                        HorizontalAlignment="Center"
                                        IsVisible="{Binding CurrentMode, Converter={StaticResource IsEditModeConverter}}"
                                        Margin="0,10,0,0">
                                    <TextBlock Text="✓ SELECTED"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Suggest Mode Box -->
                        <Border Grid.Column="2"
                                Background="#F3E5F5"
                                BorderThickness="{Binding CurrentMode, Converter={StaticResource ModeSelectionBorderThicknessConverter}, ConverterParameter=Suggest}"
                                CornerRadius="10"
                                Padding="30"
                                Cursor="Hand"
                                Tapped="OnSuggestModeBoxTapped"
                                BoxShadow="0 4 8 0 #40000000">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding CurrentMode, Converter={StaticResource ModeSelectionBorderColorConverter}, ConverterParameter=Suggest}"/>
                            </Border.BorderBrush>
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="BoxShadow" Value="0 6 16 0 #60000000"/>
                                </Style>
                            </Border.Styles>
                            <StackPanel Spacing="15">
                                <TextBlock Text="💡 Suggest Mode"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#6A1B9A"
                                           HorizontalAlignment="Center"/>
                                <TextBlock Text="Propose translation changes for review"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Foreground="#8E24AA"/>
                                <Border Height="2" Background="#E1BEE7" Margin="0,5,0,5"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#424242">
                                    <Run Text="• Suggest updates to existing values"/><LineBreak/>
                                    <Run Text="• Suggest translations for new keys"/><LineBreak/>
                                    <Run Text="• Cannot modify actual values"/><LineBreak/>
                                    <Run Text="• Suggestions include your username"/>
                                </TextBlock>
                                <!-- Selected indicator -->
                                <Border Background="#7B1FA2"
                                        CornerRadius="5"
                                        Padding="10,5"
                                        HorizontalAlignment="Center"
                                        IsVisible="{Binding CurrentMode, Converter={StaticResource IsSuggestModeConverter}}"
                                        Margin="0,10,0,0">
                                    <TextBlock Text="✓ SELECTED"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- Deployment Mode Box (Developer Only) -->
                        <Border Grid.Column="4"
                                Background="#FFF3E0"
                                BorderThickness="{Binding CurrentMode, Converter={StaticResource ModeSelectionBorderThicknessConverter}, ConverterParameter=Deployment}"
                                CornerRadius="10"
                                Padding="30"
                                Cursor="Hand"
                                Tapped="OnDeploymentModeBoxTapped"
                                BoxShadow="0 4 8 0 #40000000"
                                IsVisible="{Binding IsDeveloper}">
                            <Border.BorderBrush>
                                <SolidColorBrush Color="{Binding CurrentMode, Converter={StaticResource ModeSelectionBorderColorConverter}, ConverterParameter=Deployment}"/>
                            </Border.BorderBrush>
                            <Border.Styles>
                                <Style Selector="Border:pointerover">
                                    <Setter Property="BoxShadow" Value="0 6 16 0 #60000000"/>
                                </Style>
                            </Border.Styles>
                            <StackPanel Spacing="15">
                                <TextBlock Text="🚀 Deployment Mode"
                                           FontSize="24"
                                           FontWeight="Bold"
                                           Foreground="#E65100"
                                           HorizontalAlignment="Center"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Deploy translations directly to repository"
                                           FontSize="16"
                                           TextWrapping="Wrap"
                                           HorizontalAlignment="Center"
                                           Foreground="#F57C00"/>
                                <Border Height="2" Background="#FFE0B2" Margin="0,5,0,5"/>
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="14"
                                           Foreground="#424242">
                                    <Run Text="• Skip editing - fast deployment"/><LineBreak/>
                                    <Run Text="• Auto-validate paths before deploy"/><LineBreak/>
                                    <Run Text="• Deploy to original repo locations"/><LineBreak/>
                                    <Run Text="• Developer mode only"/>
                                </TextBlock>
                                <!-- Selected indicator -->
                                <Border Background="#FF6F00"
                                        CornerRadius="5"
                                        Padding="10,5"
                                        HorizontalAlignment="Center"
                                        IsVisible="{Binding CurrentMode, Converter={StaticResource IsDeploymentModeConverter}}"
                                        Margin="0,10,0,0">
                                    <TextBlock Text="✓ SELECTED"
                                               Foreground="White"
                                               FontWeight="Bold"
                                               FontSize="14"/>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </DockPanel>

            <!-- Step 4: Edit/Suggest Translations -->
            <DockPanel IsVisible="{Binding ShowEditStep}" LastChildFill="True">
                <!-- Bottom buttons with Save Progress on left, workflow buttons on right -->
                <Grid DockPanel.Dock="Bottom" Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <!-- Save Progress on the left -->
                    <Button Grid.Column="0"
                            Content="Save Progress"
                            Command="{Binding SaveProgressCommand}"
                            IsEnabled="{Binding HasUnsavedChanges}"
                            Padding="15,8"
                            HorizontalAlignment="Left"/>
                    
                    <!-- Workflow navigation buttons on the right -->
                    <StackPanel Grid.Column="1"
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right" 
                                Spacing="10">
                        <Button Content="{Binding StartOverButtonText}"
                                Command="{Binding StartOverCommand}"
                                Padding="15,8"/>
                        <Button Content="Next →"
                                Classes="PrimaryButton"
                                Command="{Binding CompleteEditCommand}"
                                CommandParameter="{Binding $parent[Window]}"
                                IsEnabled="{Binding HasKeys}"
                                Padding="15,8"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </Grid>

                <!-- Main content area with Grid layout -->
                <Grid RowDefinitions="Auto,Auto,*">
                    <!-- Title and Action Buttons Row -->
                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        
                        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                            <TextBlock Text="Step 4: Edit/Suggest Translations"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                                       VerticalAlignment="Center"/>
                            
                            <!-- Mode Indicator Badge -->
                            <Border CornerRadius="12"
                                    Padding="12,4"
                                    VerticalAlignment="Center">
                                <Border.Background>
                                    <SolidColorBrush Color="{Binding CurrentMode, Converter={StaticResource EditModeColorConverter}}" Opacity="0.15"/>
                                </Border.Background>
                                <Border.BorderBrush>
                                    <SolidColorBrush Color="{Binding CurrentMode, Converter={StaticResource EditModeColorConverter}}"/>
                                </Border.BorderBrush>
                                <Border.BorderThickness>1.5</Border.BorderThickness>
                                <TextBlock Text="{Binding CurrentMode, Converter={StaticResource EditModeTextConverter}}"
                                           FontSize="13"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center">
                                    <TextBlock.Foreground>
                                        <SolidColorBrush Color="{Binding CurrentMode, Converter={StaticResource EditModeColorConverter}}"/>
                                    </TextBlock.Foreground>
                                </TextBlock>
                            </Border>
                        </StackPanel>
                        
                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                            <Button Content="{Binding ShowFilters, Converter={StaticResource ShowFiltersTextConverter}, FallbackValue='Show Filters'}"
                                    Command="{Binding ToggleFiltersCommand}"
                                    Padding="10,5"/>
                            <Button Content="Add Key"
                                    Command="{Binding AddKeyCommand}"
                                    CommandParameter="{Binding $parent[Window]}"
                                    IsEnabled="{Binding HasKeys}"
                                    Padding="10,5"
                                    FontWeight="SemiBold"/>
                        </StackPanel>
                    </Grid>

                    <!-- Filters Row (collapsible) -->
                    <StackPanel Grid.Row="1" 
                                Orientation="Horizontal" 
                                HorizontalAlignment="Right"
                                Spacing="10"
                                Margin="0,0,0,15"
                                IsVisible="{Binding ShowFilters}">
                        <Button Content="Reset Filters"
                                Command="{Binding ResetFiltersCommand}"
                                Padding="10,5"/>
                        <CheckBox Content="Show Original Values"
                                  IsChecked="{Binding ShowOriginalValues}"
                                  IsVisible="{Binding CurrentMode, Converter={StaticResource IsEditModeConverter}}"
                                  VerticalAlignment="Center"
                                  ToolTip.Tip="Toggle between current and original values to see what changed"/>
                        
                        <!-- More Filters Button with Flyout -->
                        <Button Content="More Filters"
                                Padding="10,5"
                                VerticalAlignment="Center">
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <StackPanel Spacing="8" Margin="10">
                                        <CheckBox Content="Only Missing Translations"
                                                  IsChecked="{Binding ShowOnlyMissingTranslations}"
                                                  ToolTip.Tip="Show only keys with missing translations"/>
                                        <CheckBox Content="Only With Suggestions"
                                                  IsChecked="{Binding ShowOnlyWithSuggestions}"
                                                  ToolTip.Tip="Show only keys that have suggestions"/>
                                        <CheckBox Content="Only Unconfirmed"
                                                  IsChecked="{Binding ShowOnlyUnconfirmed}"
                                                  IsVisible="{Binding CurrentMode, Converter={StaticResource IsEditModeConverter}}"
                                                  ToolTip.Tip="Show only keys that are unconfirmed (missing translations or lacking confirmation audit)"/>
                                    </StackPanel>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        
                        <TextBox Text="{Binding SearchText}"
                                 PlaceholderText="Search keys and values..."
                                 MinWidth="200"
                                 Width="200"
                                 VerticalAlignment="Center"/>
                        
                        <!-- Namespace Filter Dropdown-style Button -->
                        <Button MinWidth="200" 
                                Height="32"
                                Padding="10,5"
                                HorizontalContentAlignment="Stretch"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ComboBoxBackground}"
                                BorderBrush="{DynamicResource ComboBoxBorderBrush}"
                                BorderThickness="1">
                            <Button.Content>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding SelectedNamespacesText}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Path Grid.Column="1"
                                          Data="M 0,0 L 4,4 L 8,0"
                                          Stroke="{DynamicResource ComboBoxDropDownGlyphForeground}"
                                          StrokeThickness="1"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"/>
                                </Grid>
                            </Button.Content>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <ScrollViewer MaxHeight="200" MinWidth="200" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding NamespaceFilterItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:NamespaceFilterItem">
                                                    <CheckBox IsChecked="{Binding IsSelected}" 
                                                              Margin="5,3">
                                                        <StackPanel Orientation="Horizontal" Spacing="5">
                                                            <TextBlock Text="{Binding DisplayName}"/>
                                                            <TextBlock Text="{Binding FileCount, StringFormat='({0})'}"
                                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                       FontSize="11"/>
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                        
                        <!-- File Filter Dropdown-style Button -->
                        <Button MinWidth="300" 
                                Height="32"
                                Padding="10,5"
                                HorizontalContentAlignment="Stretch"
                                VerticalAlignment="Center"
                                Background="{DynamicResource ComboBoxBackground}"
                                BorderBrush="{DynamicResource ComboBoxBorderBrush}"
                                BorderThickness="1">
                            <Button.Content>
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" 
                                               Text="{Binding SelectedFilesText}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                    <Path Grid.Column="1"
                                          Data="M 0,0 L 4,4 L 8,0"
                                          Stroke="{DynamicResource ComboBoxDropDownGlyphForeground}"
                                          StrokeThickness="1"
                                          VerticalAlignment="Center"
                                          Margin="8,0,0,0"/>
                                </Grid>
                            </Button.Content>
                            <Button.Flyout>
                                <Flyout Placement="BottomEdgeAlignedLeft">
                                    <ScrollViewer MaxHeight="250" MinWidth="300" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding FileFilterItems}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="models:FileFilterItem">
                                                    <CheckBox IsChecked="{Binding IsSelected}" 
                                                              Margin="5,3">
                                                        <StackPanel Spacing="2">
                                                            <TextBlock Text="{Binding DisplayName}"/>
                                                            <TextBlock Text="{Binding TruncatedDirectoryPath}"
                                                                       FontSize="10"
                                                                       FontStyle="Italic"
                                                                       Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                                       IsVisible="{Binding TruncatedDirectoryPath, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                                        </StackPanel>
                                                    </CheckBox>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Flyout>
                            </Button.Flyout>
                        </Button>
                    </StackPanel>

                    <!-- DataGrid with constrained height -->
                    <Border Grid.Row="2"
                            BorderThickness="1"
                            BorderBrush="Gray">
                        <DataGrid x:Name="TranslationsGrid"
                                  ItemsSource="{Binding TranslationStore.FilteredKeys}"
                                  AutoGenerateColumns="False"
                                  IsReadOnly="True"
                                  GridLinesVisibility="All"
                                  CanUserResizeColumns="True"
                                  CanUserReorderColumns="False"
                                  DoubleTapped="OnGridDoubleTapped"
                                  ToolTip.Tip="{Binding CurrentMode, Converter={StaticResource EditModeTooltipConverter}}">                                  
                            <DataGrid.Styles>
                                <Style Selector="DataGridRow" x:DataType="models:TranslationKey">
                                    <Setter Property="Background" Value="{Binding HasMissingTranslations, Converter={StaticResource MissingTranslationBorderConverter}}"/>
                                </Style>
                            </DataGrid.Styles>
                            <DataGrid.Columns>
                                <DataGridTemplateColumn Header="Source File" 
                                                        Width="*" 
                                                        MinWidth="120"
                                                        MaxWidth="250">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate DataType="models:TranslationKey">
                                            <StackPanel Orientation="Vertical" 
                                                        Margin="5,4"
                                                        VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Source, Converter={StaticResource SourceFileConverter}}" 
                                                           TextWrapping="Wrap"/>
                                                <TextBlock Text="{Binding Source.DirectoryPath, Converter={StaticResource TruncatedDirectoryPathConverter}}"
                                                           FontSize="10"
                                                           FontStyle="Italic"
                                                           Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                                                           TextWrapping="Wrap"
                                                           IsVisible="{Binding Source.DirectoryPath, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                                <DataGridTemplateColumn Header="Key" 
                                                        Width="1.5*" 
                                                        MinWidth="150"
                                                        MaxWidth="300">
                                    <DataGridTemplateColumn.CellTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding Key}" 
                                                       TextWrapping="Wrap"
                                                       Padding="5,4"
                                                       VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </DataGridTemplateColumn.CellTemplate>
                                </DataGridTemplateColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>
                </Grid>
            </DockPanel>

            <!-- Step 5: Export Files -->
            <DockPanel IsVisible="{Binding ShowExportStep}" LastChildFill="True">
                <!-- Action buttons at bottom -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Spacing="10"
                            Margin="0,15,0,0">
                    <Button Content="{Binding StartOverButtonText}"
                            Command="{Binding StartOverCommand}"
                            Padding="15,8"/>
                    <Button Content="← Back to Edit"
                            Command="{Binding GoBackToEditCommand}"
                            Padding="15,8"/>
                </StackPanel>

                <!-- Header at top -->
                <StackPanel DockPanel.Dock="Top" Spacing="5" Margin="0,0,0,15">
                    <TextBlock Text="Step 5: Export Translations"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Text="Your translations are ready to export. They will be packaged into a ZIP file with a timestamp."
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <!-- Main content -->
                <Border BorderBrush="#4CAF50"
                        BorderThickness="2"
                        Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                        CornerRadius="8"
                        Padding="30"
                        MinHeight="180"
                        MaxHeight="350">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="18">
                        <TextBlock Text="✓" FontSize="56" HorizontalAlignment="Center" Foreground="#4CAF50"/>
                        <TextBlock Text="Translations Ready for Export" 
                                   FontSize="17" 
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding StatusMessage}" 
                                   FontSize="13" 
                                   Opacity="0.8"
                                   HorizontalAlignment="Center"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   MaxWidth="350"/>
                        <Button Content="Export as ZIP"
                                Classes="ExportButton"
                                Command="{Binding ExportToZipCommand}"
                                HorizontalAlignment="Center"
                                Padding="28,11"
                                FontWeight="SemiBold"
                                Margin="0,8,0,0"/>
                    </StackPanel>
                </Border>
            </DockPanel>

            <!-- Step 6: Deploy to Repository -->
            <DockPanel IsVisible="{Binding ShowDeployStep}" LastChildFill="True">
                <!-- Action buttons at bottom -->
                <StackPanel DockPanel.Dock="Bottom"
                            Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            Spacing="10"
                            Margin="0,15,0,0">
                    <Button Content="View Exported Files"
                            Command="{Binding ViewExportedFilesCommand}"
                            Padding="15,8"/>
                    <Button Content="Start Over"
                            Command="{Binding StartOverCommand}"
                            Padding="15,8"/>
                    <Button Content="Deploy Again"
                            Command="{Binding DeployAgainCommand}"
                            IsVisible="{Binding ShowDeployAgainButton}"
                            Padding="15,8"/>
                    <Button Content="Validate &amp; Deploy"
                            Classes="PrimaryButton"
                            Command="{Binding ValidateAndDeployCommand}"
                            IsEnabled="{Binding CanDeploy}"
                            Padding="15,8"/>
                </StackPanel>

                <!-- Header at top -->
                <StackPanel DockPanel.Dock="Top" Spacing="5" Margin="0,0,0,15">
                    <TextBlock Text="Step 6: Deploy to Repository"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
                    <TextBlock Text="Select the deployment root directory and review the file paths before deploying."
                               TextWrapping="Wrap"
                               FontSize="14"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                </StackPanel>

                <!-- Main content -->
                <ScrollViewer>
                    <StackPanel Spacing="15">
                        <!-- Deployment Root Selection -->
                        <Border BorderBrush="#FF9800"
                                BorderThickness="2"
                                Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                CornerRadius="8"
                                Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="Deployment Root Directory"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#E65100"/>
                                
                                <!-- Smart suggestion (if available) -->
                                <Border Background="#FFF3E0"
                                        BorderBrush="#FFE0B2"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12"
                                        IsVisible="{Binding HasSuggestedDeploymentRoot}">
                                    <StackPanel Spacing="8">
                                        <TextBlock Text="💡 Smart Suggestion"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="#F57C00"/>
                                        <TextBlock Text="{Binding SuggestedDeploymentRoot}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap"
                                                   Foreground="#424242"/>
                                        <Button Content="Use Suggestion"
                                                Command="{Binding UseSuggestedRootCommand}"
                                                Padding="10,5"
                                                FontSize="12"
                                                HorizontalAlignment="Left"/>
                                    </StackPanel>
                                </Border>

                                <!-- Current selection or prompt -->
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding DeploymentRootPath}"
                                               FontSize="14"
                                               VerticalAlignment="Center"
                                               TextWrapping="Wrap"
                                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                    <Button Grid.Column="1"
                                            Content="Select Folder"
                                            Command="{Binding SelectDeploymentRootCommand}"
                                            Padding="12,6"
                                            Margin="10,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Validation Results -->
                        <Border BorderBrush="#2196F3"
                                BorderThickness="2"
                                Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                CornerRadius="8"
                                Padding="20"
                                IsVisible="{Binding HasValidationMessage}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Validation"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#1976D2"/>
                                <TextBlock Text="{Binding ValidationMessage}"
                                           FontSize="14"
                                           TextWrapping="Wrap"
                                           Foreground="{Binding ValidationMessageColor}"/>
                            </StackPanel>
                        </Border>

                        <!-- Deployment Preview -->
                        <Border BorderBrush="#4CAF50"
                                BorderThickness="2"
                                Background="{DynamicResource SystemControlAcrylicWindowBrush}"
                                CornerRadius="8"
                                Padding="20"
                                IsVisible="{Binding HasDeploymentPreview}">
                            <StackPanel Spacing="10">
                                <TextBlock Text="Deployment Preview"
                                           FontSize="16"
                                           FontWeight="SemiBold"
                                           Foreground="#388E3C"/>
                                <TextBlock Text="{Binding DeploymentPreviewSummary}"
                                           FontSize="13"
                                           Foreground="#666666"
                                           Margin="0,0,0,5"/>
                                
                                <ScrollViewer MaxHeight="300">
                                    <ItemsControl ItemsSource="{Binding DeploymentPreviewItems}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="#F5F5F5"
                                                        BorderBrush="#E0E0E0"
                                                        BorderThickness="1"
                                                        CornerRadius="4"
                                                        Padding="10"
                                                        Margin="0,0,0,5">
                                                    <Grid ColumnDefinitions="*,Auto,*">
                                                        <TextBlock Grid.Column="0"
                                                                   Text="{Binding SourcePath}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Courier New"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text=" → "
                                                                   FontSize="12"
                                                                   Margin="8,0"
                                                                   Foreground="#4CAF50"/>
                                                        <TextBlock Grid.Column="2"
                                                                   Text="{Binding TargetPath}"
                                                                   FontSize="12"
                                                                   TextWrapping="Wrap"
                                                                   FontFamily="Courier New"/>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Grid>
        </DockPanel>
    </Panel>

</Window>
