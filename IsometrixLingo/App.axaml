<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="IsometrixLingo.App"
             xmlns:local="using:IsometrixLingo"
             xmlns:converters="using:IsometrixLingo.Converters"
             RequestedThemeVariant="Default">
             <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>
  
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary>
                    <converters:EditModeColorConverter x:Key="EditModeColorConverter"/>
                    <converters:EditModeTextConverter x:Key="EditModeTextConverter"/>
                    <converters:EditModeTooltipConverter x:Key="EditModeTooltipConverter"/>
                    <converters:HasSuggestionConverter x:Key="HasSuggestionConverter"/>
                    <converters:SuggestionTextConverter x:Key="SuggestionTextConverter"/>
                    <converters:EditModeAndHasSuggestionConverter x:Key="EditModeAndHasSuggestionConverter"/>
                    <converters:AddKeyDialogTitleConverter x:Key="AddKeyDialogTitleConverter"/>
                    <converters:AddKeyGuidanceConverter x:Key="AddKeyGuidanceConverter"/>
                    <converters:EditDialogTitleConverter x:Key="EditDialogTitleConverter"/>
                    <converters:EditDialogLabelConverter x:Key="EditDialogLabelConverter"/>
                    <converters:IsEditModeConverter x:Key="IsEditModeConverter"/>
                    <converters:IsSuggestModeConverter x:Key="IsSuggestModeConverter"/>
                    <converters:IsDeploymentModeConverter x:Key="IsDeploymentModeConverter"/>
                    <converters:ModeSelectionBorderColorConverter x:Key="ModeSelectionBorderColorConverter"/>
                    <converters:ModeSelectionBorderThicknessConverter x:Key="ModeSelectionBorderThicknessConverter"/>
                </ResourceDictionary>
            </ResourceDictionary.MergedDictionaries>
            
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Light">
                    <SolidColorBrush x:Key="SuggestionTextBrush" Color="#4A148C"/>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Dark">
                    <SolidColorBrush x:Key="SuggestionTextBrush" Color="White"/>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
        </ResourceDictionary>
    </Application.Resources>
  
    <Application.Styles>
        <FluentTheme />
        <StyleInclude Source="avares://Avalonia.Controls.DataGrid/Themes/Fluent.xaml"/>
        
        <!-- Custom charcoal background for dark mode only -->
        <Style Selector="Window:dark">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>
        <Style Selector="DockPanel:dark">
            <Setter Property="Background" Value="#1E1E1E"/>
        </Style>
        
        <!-- Improve button readability in light mode -->
        <Style Selector="Button:light">
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
    </Application.Styles>
</Application>