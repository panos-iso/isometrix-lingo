<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TranslationManagementTool.ViewModels"
        xmlns:converters="using:TranslationManagementTool.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        x:Class="TranslationManagementTool.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Translation Management Tool"
        Width="1000" Height="600">

    <Window.Resources>
        <converters:SourceFileConverter x:Key="SourceFileConverter"/>
    </Window.Resources>

    <Design.DataContext>
        <!-- This only sets the DataContext for the previewer in an IDE,
             to set the actual DataContext for runtime, set the DataContext property in code (look at App.axaml.cs) -->
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Top Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <Button Content="Import Files"
                    Command="{Binding ImportFilesCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    Margin="0,0,10,0"/>
            
            <Button Content="Export All"
                    Command="{Binding ExportModifiedFilesCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    IsEnabled="{Binding HasKeys}"
                    Margin="0,0,10,0"/>
            
            <Button Content="Add Key"
                    Command="{Binding AddKeyCommand}"
                    CommandParameter="{Binding $parent[Window]}"
                    IsEnabled="{Binding HasKeys}"
                    Margin="0,0,10,0"/>
            
            <TextBlock Text="Search:" 
                       VerticalAlignment="Center" 
                       Margin="20,0,5,0"/>
            <TextBox Text="{Binding SearchText}"
                     PlaceholderText="Search keys and values..."
                     MinWidth="250"
                     VerticalAlignment="Center"/>
        </StackPanel>

        <!-- File Filters Panel -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10,0,10,10">
            <TextBlock Text="Filter by file:" 
                       VerticalAlignment="Center" 
                       Margin="0,0,10,0"
                       FontWeight="SemiBold"/>
            <ItemsControl ItemsSource="{Binding FileFilters}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <ToggleButton Content="{Binding DisplayName}"
                                      IsChecked="{Binding IsSelected}"
                                      Command="{Binding $parent[Window].DataContext.ToggleFileFilterCommand}"
                                      CommandParameter="{Binding}"
                                      Margin="0,0,5,0"
                                      Padding="10,5"/>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>

        <!-- Bottom Status Bar -->
        <TextBlock DockPanel.Dock="Bottom"
                   Text="{Binding StatusMessage}"
                   Background="LightGray"
                   Padding="10,5"/>

        <!-- Main Content Area -->
        <Grid Margin="10">
            <DataGrid x:Name="TranslationsGrid"
                      ItemsSource="{Binding TranslationStore.FilteredKeys}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      GridLinesVisibility="All"
                      BorderThickness="1"
                      BorderBrush="Gray"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="False">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Key" 
                                        Binding="{Binding Key}" 
                                        Width="Auto" 
                                        MinWidth="150" 
                                        MaxWidth="400"/>
                    <DataGridTextColumn Header="Source File" 
                                        Binding="{Binding Source, Converter={StaticResource SourceFileConverter}}" 
                                        Width="Auto" 
                                        MinWidth="150" 
                                        MaxWidth="250"/>
                    <DataGridTemplateColumn Header="Actions" Width="Auto">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Button Content="Edit"
                                        Command="{Binding $parent[Window].DataContext.EditTranslationCommand}"
                                        CommandParameter="{Binding}"
                                        Margin="5,2"
                                        Padding="15,5"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                    <!-- Language columns will be added dynamically in code-behind -->
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </DockPanel>

</Window>
